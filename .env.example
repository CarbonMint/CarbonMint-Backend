# Server
PORT=4000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# CORS: '*' allows any origin; in production set a comma-separated allowlist,
# e.g. CORS_ORIGIN=https://app.carbonmint.io,https://admin.carbonmint.io
CORS_ORIGIN=*

# Mock Stellar / Soroban network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_CONTRACT_ID=CMINTMOCK000000000000000000000000000000000000000000000000

# Marketplace
PLATFORM_FEE_BPS=150
